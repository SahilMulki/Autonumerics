{
  "equation_type": "Poisson",
  "governing_equation": "-Δu = f(x, y)",
  "spatial_dimension": 2,
  "time_dependent": false,
  "spatial_variables": [
    "x",
    "y"
  ],
  "time_variable": null,
  "domain": {
    "bounds": {
      "x": [
        0.0,
        1.0
      ],
      "y": [
        0.0,
        1.0
      ]
    },
    "x_min": 0.0,
    "x_max": 1.0,
    "y_min": 0.0,
    "y_max": 1.0
  },
  "initial_condition": null,
  "boundary_conditions": {
    "type": "Dirichlet",
    "values": {
      "u(x, y) on boundary": "0"
    }
  },
  "parameters": {},
  "analytic_solution": {
    "expression": "sin(pi*x)*sin(pi*y)",
    "space_variables": [
      "x",
      "y"
    ]
  },
  "notes": null,
  "id": "poisson_2d_dirichlet_sin_sin",
  "family": "poisson",
  "dimension": 2
}