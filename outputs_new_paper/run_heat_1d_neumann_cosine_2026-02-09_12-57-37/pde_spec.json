{
  "equation_type": "heat",
  "governing_equation": "u_t = alpha * u_xx",
  "spatial_dimension": 1,
  "time_dependent": true,
  "spatial_variables": [
    "x"
  ],
  "time_variable": "t",
  "domain": {
    "bounds": {
      "x": [
        0.0,
        1.0
      ]
    },
    "x_min": 0.0,
    "x_max": 1.0
  },
  "initial_condition": "cos(pi*x)",
  "boundary_conditions": {
    "type": "Neumann",
    "values": {
      "x=0": "u_x=0",
      "x=1": "u_x=0"
    }
  },
  "parameters": {
    "alpha": 0.1
  },
  "analytic_solution": {
    "expression": "exp(-0.1*pi^2*t) * cos(pi*x)",
    "space_variables": [
      "x"
    ]
  },
  "notes": null,
  "id": "heat_1d_neumann_cosine",
  "family": "heat",
  "dimension": 1
}