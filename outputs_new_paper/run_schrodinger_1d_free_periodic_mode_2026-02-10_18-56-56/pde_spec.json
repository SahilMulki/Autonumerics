{
  "equation_type": "Schrödinger",
  "governing_equation": "1j*u_t = -0.5*u_xx",
  "spatial_dimension": 1,
  "time_dependent": true,
  "spatial_variables": [
    "x"
  ],
  "time_variable": "t",
  "domain": {
    "bounds": {
      "x": [
        0.0,
        6.283185307179586
      ]
    },
    "x_min": 0.0,
    "x_max": 6.283185307179586
  },
  "initial_condition": "np.exp(1j*1*x)",
  "boundary_conditions": {
    "type": "periodic",
    "values": {}
  },
  "parameters": {
    "m": 1
  },
  "analytic_solution": {
    "expression": "np.exp(1j*m*x) * np.exp(-1j*0.5*m**2*t)",
    "space_variables": [
      "x"
    ]
  },
  "notes": null,
  "id": "schrodinger_1d_free_periodic_mode",
  "family": "schrodinger",
  "dimension": 1
}