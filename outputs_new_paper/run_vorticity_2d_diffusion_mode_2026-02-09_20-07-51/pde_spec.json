{
  "equation_type": "Vorticity Diffusion",
  "governing_equation": "omega_t = nu * (omega_xx + omega_yy)",
  "spatial_dimension": 2,
  "time_dependent": true,
  "spatial_variables": [
    "x",
    "y"
  ],
  "time_variable": "t",
  "domain": {
    "bounds": {
      "x": [
        0.0,
        1.0
      ],
      "y": [
        0.0,
        1.0
      ],
      "t": [
        0.0,
        0.5
      ]
    },
    "x_min": 0.0,
    "x_max": 1.0,
    "y_min": 0.0,
    "y_max": 1.0
  },
  "initial_condition": "np.sin(2 * np.pi * x) * np.sin(2 * np.pi * y)",
  "boundary_conditions": {
    "type": "periodic",
    "values": {}
  },
  "parameters": {
    "nu": 0.05
  },
  "analytic_solution": {
    "expression": "np.exp(-nu * (2 * np.pi)**2 * 2 * t) * np.sin(2 * np.pi * x) * np.sin(2 * np.pi * y)",
    "space_variables": [
      "x",
      "y"
    ]
  },
  "notes": null,
  "id": "vorticity_2d_diffusion_mode",
  "family": "vorticity",
  "dimension": 2
}